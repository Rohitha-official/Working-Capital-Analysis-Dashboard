      <column caption='Invoice Status' datatype='string' name='[Calculation_1389246484570113]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Is Open]=1 THEN &quot;Open&quot;&#13;&#10;ELSE &quot;Closed&quot;&#13;&#10;END' />
      </column>
      <column caption='Open Invoices' datatype='integer' name='[Calculation_1389246502490114]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(IF [Is Open]=1 THEN [Invoice ID]END)' />
      </column>
      <column aggregation='None' datatype='integer' name='[Credit limit (bin)]' role='dimension' type='quantitative'>
        <calculation class='bin' decimals='4' formula='[Credit_limit]' peg='0' size='93067' />
