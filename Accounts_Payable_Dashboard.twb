    <worksheet name='AP_Late_Fees'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontalignment='1'>Top 10 Suppliers by Late Payment Fees</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='payables_data (payables_data)' name='federated.19qy3880mn57up1acs2k00o9vx25' />
          </datasources>
          <datasource-dependencies datasource='federated.19qy3880mn57up1acs2k00o9vx25'>
            <column datatype='integer' name='[Late payment fees]' role='measure' type='quantitative' />
            <column datatype='string' name='[Supplier ID]' role='dimension' type='nominal' />
            <column-instance column='[Supplier ID]' derivation='None' name='[none:Supplier ID:nk]' pivot='key' type='nominal' />
            <column-instance column='[Late payment fees]' derivation='Sum' name='[sum:Late payment fees:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <filter class='categorical' column='[federated.19qy3880mn57up1acs2k00o9vx25].[none:Supplier ID:nk]'>
            <groupfilter count='10' end='top' function='end' units='records' user:ui-marker='end' user:ui-top-by-field='true'>
              <groupfilter direction='DESC' expression='SUM([Late payment fees])' function='order' user:ui-marker='order'>
