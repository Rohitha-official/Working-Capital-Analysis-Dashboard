      <style>
        <style-rule element='mark'>
          <encoding attr='color' field='[none:Calculation_1644332147957761:nk]' palette='traffic_light_10_0' type='palette'>
            <map to='#b60a1c'>
              <bucket>&quot;90+ Days&quot;</bucket>
