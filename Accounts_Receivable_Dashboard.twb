      <aliases enabled='yes' />
      <column caption='Baseline Date' datatype='date' name='[Baseline_Date]' role='dimension' type='ordinal' />
      <column datatype='integer' name='[Business Year]' role='dimension' type='quantitative' />
      <column caption='Days Outstanding' datatype='integer' name='[Calculation_1644332147019776]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='DATEDIFF(&apos;day&apos;,[Due_Date],[Baseline_Date])' />
      </column>
      <column caption='Aging Bucket' datatype='string' name='[Calculation_1644332147957761]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_1644332150300674] &lt;=0 THEN &quot;Current&quot;&#13;&#10;ELSEIF [Calculation_1644332150300674] &lt;=30 THEN &quot;1-30 Days&quot;&#13;&#10;ELSEIF [Calculation_1644332150300674] &lt;=60 THEN &quot;31-60 Days&quot;&#13;&#10;ELSEIF [Calculation_1644332150300674] &lt;=90 THEN &quot;61-90 Days&quot;&#13;&#10;ELSE &quot;90+ Days&quot;&#13;&#10;END' />
      </column>
      <column caption='Days Past Due' datatype='integer' name='[Calculation_1644332150300674]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='DATEDIFF(&apos;day&apos;,[Due_Date],DATE(&quot;2020-04-30&quot;))' />
      </column>
      <column caption='Credit limit' datatype='integer' default-format='c&quot;$&quot;#,##0,.00K' name='[Credit_limit]' role='measure' type='quantitative' />
      <column caption='Customer Name1' datatype='string' name='[Customer Name]' role='dimension' type='nominal' />
      <column datatype='integer' name='[Customer Number]' role='dimension' type='ordinal' />
      <column caption='Dunnlevel' datatype='integer' name='[DUNNLEVEL]' role='measure' type='quantitative' />
      <column caption='Due Date' datatype='date' name='[Due_Date]' role='dimension' type='ordinal' />
      <column caption='Invoice ID1' datatype='integer' name='[Invoice ID]' role='dimension' type='ordinal' />
      <column caption='Payment Date' datatype='string' name='[Payment_Date]' role='dimension' type='nominal' />
      <column caption='Posting Date' datatype='date' name='[Posting_Date]' role='dimension' type='ordinal' />
      <column caption='Region1' datatype='string' name='[Region]' role='dimension' type='nominal' />
      <column caption='Total Open Amount USD' datatype='real' default-format='c&quot;$&quot;#,##0,,,.00B' name='[Total Open Amount_USD]' role='measure' type='quantitative' />
      <column caption='Usd Currenncy' datatype='string' name='[USD_CURRENNCY]' role='dimension' type='nominal' />
      <column caption='receivables_data' datatype='table' name='[__tableau_internal_object_id__].[receivables!data_84385955261544D38645F84E1EA79105]' role='measure' type='quantitative' />
      <column-instance column='[Calculation_1644332147957761]' derivation='None' name='[none:Calculation_1644332147957761:nk]' pivot='key' type='nominal' />
